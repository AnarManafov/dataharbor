{
    "name": "data-lake-ui",
    "version": "0.6.0",
    "workspaces": [
        ".",
        "web"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "dev:frontend": "cd web && npm run dev",
        "dev:backend": "cd app && go run . ${CONFIG_FILE_PATH:+-config $CONFIG_FILE_PATH}",
        "build": "npm run build:frontend && npm run build:backend",
        "build:frontend": "cd web && npm run build",
        "build:backend": "cd app && go build .",
        "sandbox:create": "mkdir -p sandbox/public && cp -r web/public/* sandbox/public/",
        "sandbox:clean": "rm -rf sandbox",
        "sandbox:run": "cd web && npm run sandbox"
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    }
}
{
  "name": "dataharbor",
  "version": "1.0.9",
  "type": "module",
  "workspaces": [
    ".",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd web && npm run dev",
    "dev:backend": "cd app && go run . ${CONFIG_FILE_PATH:+-config $CONFIG_FILE_PATH}",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd web && npm run build",
    "build:backend": "./scripts/build-backend.sh dataharbor-backend",
    "sync-versions": "node tools/sync-versions.js",
    "prepare-release": "npm run sync-versions && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

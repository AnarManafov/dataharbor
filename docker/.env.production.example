# ============================================
# DataHarbor Production Environment Variables
# ============================================
# Copy this file to .env and configure for your environment
# cp .env.production.example .env

# ============================================
# XROOTD SERVER CONFIGURATION
# ============================================

# XRootD connection (backend connects to this)
# For local container XRootD: use 'xrootd' (service name)
# For external XRootD server: use actual hostname/IP
XRD_HOST=xrootd
XRD_PORT=1094
XRD_INITIAL_DIR=/
XRD_ENABLE_ZTN=true

# ============================================
# XROOTD DATA DIRECTORY - REQUIRED
# ============================================
# Path on HOST system to serve via XRootD
# Examples:
#   - Lustre: /lustre/dataharbor
#   - GPFS: /gpfs/scratch/data
#   - Local: /data/xrootd
#
# CRITICAL: For Lustre/NFS - UIDs in mapfile must match filesystem UIDs!
XROOTD_DATA_DIR=/path/to/your/data

# ============================================
# XROOTD TLS CERTIFICATES - REQUIRED
# ============================================
# Paths on HOST system to TLS certificate and private key
# These will be mounted read-only into the container
#
# Examples:
#   - Let's Encrypt: /etc/letsencrypt/live/yourdomain.com/fullchain.pem
#   - Grid CA: /etc/grid-security/hostcert.pem
#   - Custom: /opt/certs/server.crt
#
# Requirements:
#   - Certificate must be readable (recommend chmod 644)
#   - Private key must be readable (recommend chmod 600, owned by root)
#   - For grid computing: Use host certificate from CA
XRD_CERT_PATH=/etc/grid-security/hostcert.pem
XRD_KEY_PATH=/etc/grid-security/hostkey.pem

# ============================================
# XROOTD USER MAPFILE - REQUIRED
# ============================================
# Path on HOST system to SciTokens user mapping file
# Maps token 'sub' claim to Unix username
#
# Format: JSON array of mappings
# Example:
#   [
#     {"sub": "username", "result": "unixuser"},
#     {"sub": "alice", "result": "alice"},
#     {"sub": "bob", "result": "bob"}
#   ]
#
# CRITICAL REQUIREMENTS:
#   1. Unix users in "result" MUST exist on host system
#   2. UIDs must match between host and filesystem (especially Lustre/NFS)
#   3. Users must have proper permissions on XROOTD_DATA_DIR
#
# Example: /opt/xrootd/mapfile
XRD_MAPFILE_PATH=/path/to/your/mapfile

# ============================================
# XROOTD CA CERTIFICATES - OPTIONAL
# ============================================
# Path on HOST system to CA certificate directory for TLS verification
#
# Options:
#   - Grid computing: /etc/grid-security/certificates
#   - System CAs: /etc/pki/tls/certs or /etc/ssl/certs
#   - Custom CA bundle: /opt/ca-certs
#   - Leave commented to disable verification (testing only!)
#
# NOTE: If using self-signed certs, set XROOTD_TLS_CA_VERIFY=false
CA_CERTS_PATH=/etc/grid-security/certificates

# ============================================
# XROOTD TLS CA VERIFICATION - OPTIONAL
# ============================================
# Set to false to disable CA verification (for self-signed certs in staging/testing)
# Default: true (production mode with proper CA verification)
XROOTD_TLS_CA_VERIFY=true

# ============================================
# HOST USER DATABASE - REQUIRED
# ============================================
# The multiuser plugin calls getpwnam() to resolve mapped usernames to UIDs.
#
# On HPC/enterprise hosts, users typically come from LDAP/AD via SSSD.
# Bind-mounting /etc/passwd alone is NOT enough — LDAP users won't be there.
# The container needs access to the host's SSSD daemon via its Unix socket.
#
# Three mounts are required:
#   1. /etc/passwd, /etc/group   — local system users (e.g. xrootd)
#   2. /etc/nsswitch.conf        — tells NSS to use 'sss' for user lookups
#   3. /var/lib/sss/pipes        — SSSD daemon socket for NSS queries
#
# The container image includes sssd-client (libnss_sss.so) to talk to the
# host's SSSD daemon via the mounted socket.
#
# REQUIREMENT: The xrootd system user must exist on the host. If not, create it:
#   groupadd -r xrootd
#   useradd -r -g xrootd -s /sbin/nologin xrootd
#
# REQUIREMENT: SSSD must be running on the host:
#   systemctl status sssd
#
HOST_PASSWD_PATH=/etc/passwd
HOST_GROUP_PATH=/etc/group
HOST_NSSWITCH_PATH=/etc/nsswitch.conf
HOST_SSSD_PIPES=/var/lib/sss/pipes

# Build-time UID/GID for the xrootd user (used for file ownership in image layers).
# At runtime the entrypoint re-chowns directories, so these are just defaults.
# Run `getent passwd xrootd` on your host to find the actual values.
XROOTD_UID=994
XROOTD_GID=993

# ============================================
# XROOTD LOGGING - OPTIONAL
# ============================================
# Path on HOST system to store XRootD logs
# Logs will be persistent across container restarts
#
# Default: ./logs/xrootd (relative to docker directory)
XROOTD_LOG_DIR=/var/log/dataharbor/xrootd

# ============================================
# BACKEND & NGINX LOGGING - OPTIONAL
# ============================================
# Paths on HOST system to store backend and nginx logs
# Defaults: ./logs/backend and ./logs/nginx (relative to docker directory)
BACKEND_LOG_DIR=/var/log/dataharbor/backend
NGINX_LOG_DIR=/var/log/dataharbor/nginx

# ============================================
# XROOTD RESOURCE LIMITS - OPTIONAL
# ============================================
# Uncomment the deploy.resources section in docker-compose.prod.yml
# and configure these limits to prevent resource exhaustion
#
# XRD_CPU_LIMIT=4.0       # Max CPU cores
# XRD_MEM_LIMIT=8G        # Max memory
# XRD_CPU_RESERVE=1.0     # Reserved CPU cores
# XRD_MEM_RESERVE=2G      # Reserved memory

# ============================================
# NGINX SSL CERTIFICATES - REQUIRED
# ============================================
# Path on HOST system to SSL certificate and private key for HTTPS gateway
#
# These are for the nginx reverse proxy (user-facing HTTPS)
# Different from XRD_CERT_PATH (which is for XRootD protocol TLS)
#
# Examples:
#   - Let's Encrypt: /etc/letsencrypt/live/yourdomain.com/fullchain.pem
#   - Commercial CA: /etc/ssl/certs/yourdomain.com.crt
SSL_CERT_PATH=/path/to/nginx/server.crt
SSL_KEY_PATH=/path/to/nginx/server.key

# ============================================
# XROOTD CLIENT CERTIFICATES - OPTIONAL
# ============================================
# For backend to authenticate to XRootD using TLS client certificates
# Only needed if XRootD requires client certificate authentication
#
# Directory should contain:
#   - client.crt (client certificate)
#   - client.key (client private key)
#
# Default: ./certs/client (will be created if not exists)
XRD_CLIENT_CERT_PATH=./certs/client

# ============================================
# AUTHENTICATION - OIDC CONFIGURATION
# ============================================
AUTH_ENABLED=true

# OIDC Provider Settings
# Example for GSI (https://id.gsi.de):
OIDC_ISSUER=https://id.gsi.de/realms/wl
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_DISCOVERY_URL=https://id.gsi.de/realms/wl/.well-known/openid-configuration

# Session Secret (generate with: openssl rand -hex 32)
OIDC_SESSION_SECRET=your-random-32-byte-hex-string

# SciTokens audience (defaults to OIDC_ISSUER if not set)
# Only set if your token audience differs from the issuer URL
# SCITOKENS_AUDIENCE=https://id.gsi.de/realms/wl

# ============================================
# FRONTEND / CORS
# ============================================
# Public URL of the deployment (used for CORS and frontend URL)
# Default: https://localhost
# CORS_ALLOW_ORIGINS=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info  # debug, info, warn, error

# ============================================
# IMAGE VERSION (docker-compose.deploy.yml only)
# ============================================
# Specify which version of DataHarbor images to deploy
# Used only with docker-compose.deploy.yml (pre-built GHCR images)
# Examples: latest, 0.14.6, v1.0.0
# Default: latest
# VERSION=latest

# ============================================
# IMAGE PULL POLICY (docker-compose.deploy.yml only)
# ============================================
# Controls when Docker pulls images from the registry
# Options:
#   - missing: Only pull if image doesn't exist locally (default, best for production)
#   - always:  Always pull before starting (best for staging with mutable tags like 'dev')
#   - never:   Never pull, only use local images
#
# For staging/testing with 'dev' tag, set to 'always' to get latest builds:
#   PULL_POLICY=always VERSION=dev docker compose -f docker-compose.deploy.yml up -d
#
# Default: missing
# PULL_POLICY=missing

# ============================================
# TIMEZONE
# ============================================
TZ=UTC  # or Europe/Berlin, America/New_York, etc.

# ============================================
# NOTES FOR LUSTRE DEPLOYMENTS
# ============================================
#
# 1. USER MAPPING:
#    - All users in mapfile must exist on Lustre client (host)
#    - UIDs must match between mapfile and Lustre
#    - Consider using LDAP/NIS for consistent UID mapping
#
# 2. SELINUX/APPARMOR:
#    - May block container access to Lustre mount
#    - Uncomment security_opt in docker-compose.prod.yml if needed
#    - Or configure SELinux context: chcon -Rt svirt_sandbox_file_t /lustre/data
#
# 3. PERFORMANCE:
#    - No significant overhead from Docker bind mount
#    - XRootD benefits from Lustre striping (automatically detected)
#    - Extended attributes enabled in xrootd-prod.cfg
#
# 4. BIND MOUNT PROPAGATION:
#    - Set to 'rslave' in docker-compose.prod.yml
#    - Ensures Lustre mount changes propagate to container
#
# 5. FILE LOCKING:
#    - Lustre POSIX locks work through bind mount
#    - No special configuration needed
#
# ============================================

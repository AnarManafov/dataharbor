# Ignore git files
.git
.gitignore

# Ignore documentation
*.md
docs/

# Ignore tests
**/*.test.js
**/*.spec.js
tests/
coverage/

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore build artifacts
dist/
build/
.cache/

# Ignore dependencies (will be installed in container)
node_modules/

# Ignore config files
.env
.env.*
!.env.example

# Ignore development files
.eslintrc*
.prettierrc*
*.config.js
!vite.config.js
!vue.config.js

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

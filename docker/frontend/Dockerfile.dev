# Frontend Development Dockerfile - Vite dev server with hot-reload

FROM node:24-alpine

RUN apk add --no-cache git

WORKDIR /app

COPY web/package*.json ./
RUN npm install  # Include dev dependencies for development

COPY web/ ./

EXPOSE 5173

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider https://localhost:5173/ || exit 1

CMD ["npm", "run", "dev"]

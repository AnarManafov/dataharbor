# ============================================
# DataHarbor - GSI Production Environment
# ============================================
# This file contains real configuration values for GSI deployment
# Keep this file secure and do NOT commit to version control!
# ============================================

# ============================================
# Host Project Path (REQUIRED)
# ============================================
# Path to the project root as seen by Docker daemon.
# - macOS/Linux native: use actual path, e.g., /Users/you/projects/dataharbor
# - WSL devcontainer: use WSL host path, e.g., /home/you/workspace/dataharbor
HOST_PROJECT_ROOT=/Users/anarmanafov/Documents/workspace/dataharbor

# ============================================
# Authentication Configuration (GSI Keycloak)
# ============================================
AUTH_ENABLED=true
OIDC_ISSUER=https://id.gsi.de/realms/wl
OIDC_CLIENT_ID=xrootd-test
OIDC_CLIENT_SECRET=a6b1924beff8eb6c78e4071314a5258185aec792d903c761fcfe5a28b3ddf8fa
OIDC_DISCOVERY_URL=https://id.gsi.de/realms/wl/.well-known/openid-configuration

# Session secret (generated with: openssl rand -hex 32)
OIDC_SESSION_SECRET=5f9d7b8e3a1c4d869f2e6b7c8d9e4f3a12a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7

# ============================================
# SSL/TLS Configuration
# ============================================
# Self-signed certificates are automatically generated by XRootD container
# and shared via the xrootd-certs Docker volume with all services
# No manual certificate configuration needed for development

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info

# ============================================
# Development Settings (for local testing)
# ============================================
# XRootD data directory (local testing only)
# This directory will be mounted as /data in the XRootD container
# Place test files here to access them via XRootD
# Default: ./xrootd-data (relative to docker directory)
XROOTD_DATA_DIR=/mnt/d/tmp

# Create many_files subdirectory with 2K files for testing (true/false)
CREATE_MANY_FILES=true

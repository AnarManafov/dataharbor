# ============================================
# DataHarbor - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# For development: docker compose up -d
# Note: XRootD server settings (host, port, ZTN) are hardcoded in docker-compose.yml
#       for the local dev XRootD container. These settings are only for production.
# ============================================

# ============================================
# Authentication Configuration
# ============================================
# Enable OIDC authentication
AUTH_ENABLED=true

# OIDC Issuer URL
OIDC_ISSUER=https://id.gsi.de/realms/wl

# OIDC Client ID
OIDC_CLIENT_ID=xrootd

# OIDC Client Secret (keep this secret!)
OIDC_CLIENT_SECRET=your-client-secret-here

# OIDC Discovery URL
OIDC_DISCOVERY_URL=https://id.gsi.de/realms/wl/.well-known/openid-configuration

# Session secret for encrypting cookies (generate with: openssl rand -hex 32)
OIDC_SESSION_SECRET=your-session-secret-here

# ============================================
# SSL/TLS Configuration
# ============================================
# Path to SSL certificate for nginx
SSL_CERT_PATH=/path/to/server.crt

# Path to SSL private key for nginx
SSL_KEY_PATH=/path/to/server.key

# ============================================
# Logging Configuration
# ============================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# Development Settings
# ============================================
# XRootD data directory (local testing only)
# This directory will be mounted as /data in the XRootD container
# Place test files here to access them via XRootD
# Default: ./xrootd-data (relative to docker directory)
XROOTD_DATA_DIR=./xrootd-data

# Create many_files subdirectory with 2K files for testing (true/false)
# Set to true to test frontend/backend browsing performance with many files
CREATE_MANY_FILES=false

{
  "name": "dataharbor_frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:with-config": "VITE_CONFIG_FILE_PATH='/config.json' vite",
    "dev:env-certs": "vite",
    "sandbox:env-certs": "vite --config vite.sandbox.config.js",
    "dev:pkm-certs": "VITE_SSL_KEY=\"$HOME/Documents/workspace/pkm/docs/gsi/dataharbor/test/cert/server.key\" VITE_SSL_CERT=\"$HOME/Documents/workspace/pkm/docs/gsi/dataharbor/test/cert/server.crt\" vite",
    "sandbox:pkm-certs": "VITE_SSL_KEY=\"$HOME/Documents/workspace/pkm/docs/gsi/dataharbor/test/cert/server.key\" VITE_SSL_CERT=\"$HOME/Documents/workspace/pkm/docs/gsi/dataharbor/test/cert/server.crt\" vite --config vite.sandbox.config.js",
    "build": "vite build",
    "preview": "vite preview",
    "sandbox": "vite --config vite.sandbox.config.js",
    "cert:check": "node scripts/check-certs.js",
    "cert:setup": "bash scripts/setup-certs-example.sh"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@types/file-saver": "^2.0.7",
    "axios": "^1.13.2",
    "element-plus": "^2.13.0",
    "file-saver": "^2.0.5",
    "jwt-decode": "^4.0.0",
    "pinia": "^3.0.4",
    "streamsaver": "^2.0.6",
    "vue": "^3.5.26",
    "vue-axios": "^3.5.2",
    "vue-router": "^4.6.4",
    "vuex": "^4.1.0",
    "web-streams-polyfill": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "sass": "^1.97.1",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.3.0"
  }
}

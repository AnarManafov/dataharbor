{
  "apiBaseUrl": "/api",
  "oidc": {
    "authority": "https://your-oidc-provider.com/realms/your-realm",
    "client_id": "your-client-id",
    "redirect_uri": "https://your-domain.com/",
    "post_logout_redirect_uri": "https://your-domain.com/",
    "response_type": "code",
    "scope": "openid profile email",
    "automaticSilentRenew": true,
    "silent_redirect_uri": "https://your-domain.com/silent-renew.html"
  },
  "features": {
    "enableDocumentation": true
  }
}

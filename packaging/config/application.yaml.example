# DataHarbor Backend Configuration Example
# Copy this file to /etc/dataharbor/application.yaml and customize for your environment

env: production

server:
  # Server address and port
  address: ":8081"
  debug: false
  shutdown_timeout: 30s
  
  # CORS configuration
  cors:
    allow_credentials: true
    allow_headers:
      - Origin
      - Content-Length
      - Content-Type
      - Authorization
    allow_methods:
      - GET
      - POST
      - PUT
      - DELETE
      - OPTIONS
    allow_origins:
      - https://your-domain.com  # Replace with your frontend domain
  
  # SSL/TLS configuration
  ssl:
    enabled: true
    cert_file: /path/to/your/server.crt  # Replace with your certificate path
    key_file: /path/to/your/server.key   # Replace with your key path

# Logging configuration
logging:
  level: info  # Options: debug, info, warn, error
  console:
    enabled: true
    level: info
    format: text  # Options: text, json
  file:
    enabled: true
    level: info
    filename: "/var/log/dataharbor/dataharbor-backend.log"
    maxsize: 10      # MB
    maxbackups: 3    # Number of old log files to keep
    maxage: 28       # Days
    compress: true

# XRootD configuration
xrd:
  host: "localhost"
  port: 1094
  initial_dir: "/"  # XRootD root directory
  user: ""
  usergroup: ""
  enable_ztn: true  # Enable ZTN protocol (TLS + OAuth token authentication)
  client_cert: ""   # Optional: Client certificate for XRootD authentication
  client_key: ""    # Optional: Client key for XRootD authentication

# Frontend configuration
frontend:
  url: "https://your-domain.com"  # MUST match your actual frontend URL
  dist_dir: "dist"
  asset_paths:
    - "../sandbox/public"
    - "web"

# Authentication configuration
auth:
  enabled: true
  skip_auth_paths:
    - "/health"
    - "/api/auth/login"
    - "/api/auth/callback"
  
  # OIDC (OpenID Connect) configuration
  oidc:
    issuer: "https://your-oidc-provider.com/realms/your-realm"
    client_id: "your-client-id"
    client_secret: "YOUR-CLIENT-SECRET-HERE"  # IMPORTANT: Replace with actual secret
    discovery_url: "https://your-oidc-provider.com/realms/your-realm/.well-known/openid-configuration"
    allowed_roles:
      - "user"  # Replace with roles from your OIDC provider
    session_secret: "GENERATE-A-RANDOM-SECRET-STRING-HERE"  # IMPORTANT: Generate unique random string
    token_refresh_buffer_sec: 60

# CONFIGURATION NOTES:
#
# 1. OIDC Secrets:
#    - client_secret: Get from your OIDC provider (Keycloak, Auth0, etc.)
#    - session_secret: Generate with: openssl rand -base64 32
#
# 2. Frontend URL:
#    - MUST be the actual URL users access (not localhost for production)
#    - Used for OAuth redirects
#
# 3. XRootD Settings:
#    - enable_ztn: Set to true if XRootD requires OAuth token authentication
#    - initial_dir: Must match your XRootD export path
#
# 4. SSL Certificates:
#    - Use proper CA-signed certificates for production
#    - Self-signed certificates work for testing but show browser warnings
#
# 5. For GSI Deployment:
#    - Use port 22000 (server.address: ":22000")
#    - SSL certs at /etc/ssl/certs/ and /etc/ssl/private/
#    - Enable ZTN (enable_ztn: true)
#    - Frontend URL should be https://your-server.gsi.de
